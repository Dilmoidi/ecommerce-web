    {
      "cell_type": "code",
      "source": [
        "def predict_sentiment(text):\n",
        "    text = clean_text(text)\n",
        "    vector = vectorizer.transform([text])\n",
        "    prediction = lr_model.predict(vector)[0]\n",
        "\n",
        "    labels = {\n",
        "        0: \"Negative\",\n",
        "        1: \"Neutral\",\n",
        "        2: \"Positive\"\n",
        "    }\n",
        "\n",
        "    return labels[prediction]"
      ],
      "metadata": {
        "id": "45OuLTSNS1De"
      },
      "execution_count": 26,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(predict_sentiment(\"movie super aanu\"))\n",
        "print(predict_sentiment(\"waste padam\"))\n",
        "print(predict_sentiment(\"average movie\"))"
      ],
