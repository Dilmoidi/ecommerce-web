    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "\n",
        "all_data = []\n",
        "\n",
        "categories = [\n",
        "    movie_positive, movie_negative, movie_neutral,\n",
        "    food_positive, food_negative, food_neutral,\n",
        "    shopping_positive, shopping_negative, shopping_neutral,\n",
        "    travel_positive, travel_negative, travel_neutral,\n",
        "    education_positive, education_negative, education_neutral,\n",
        "    social_positive, social_negative, social_neutral\n",
        "]\n",
        "\n",
        "for category in categories:\n",
        "    for text in category:\n",
        "        if category in [movie_positive, food_positive, shopping_positive, travel_positive, education_positive, social_positive]:\n",
        "            sentiment = \"positive\"\n",
        "        elif category in [movie_negative, food_negative, shopping_negative, travel_negative, education_negative, social_negative]:\n",
        "            sentiment = \"negative\"\n",
        "        else:\n",
        "            sentiment = \"neutral\"\n",
        "\n",
        "        all_data.append([text, sentiment])\n",
        "\n",
        "df = pd.DataFrame(all_data, columns=[\"text\", \"sentiment\"])\n",
        "\n",
        "print(df.shape)\n",
        "df.head()"
      ],
