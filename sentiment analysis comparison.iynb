        "def predict_svm(text):\n",
        "    text = clean_text(text)\n",
        "    vector = vectorizer.transform([text])\n",
        "    prediction = svm_model.predict(vector)[0]\n",
        "\n",
        "    labels = {\n",
        "        0: \"Negative\",\n",
        "        1: \"Neutral\",\n",
        "        2: \"Positive\"\n",
        "    }\n",
        "\n",
        "    return labels[prediction]"
      ],
      "metadata": {
        "id": "8Gp9jMBlToMl"
      },
      "execution_count": 41,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
