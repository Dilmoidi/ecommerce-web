      "cell_type": "code",
      "source": [
        "def predict_nb(text):\n",
        "    text = clean_text(text)\n",
        "    vector = vectorizer.transform([text])\n",
        "    prediction = nb_model.predict(vector)[0]\n",
        "\n",
        "    labels = {\n",
        "        0: \"Negative\",\n",
        "        1: \"Neutral\",\n",
        "        2: \"Positive\"\n",
        "    }\n",
        "\n",
        "    return labels[prediction]"
      ],
      "metadata": {
        "id": "RZKtCF0ATM4a"
      },
      "execution_count": 33,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(predict_nb(\"movie super aanu\"))\n",
        "print(predict_nb(\"waste padam\"))\n",
