    {
      "cell_type": "code",
      "source": [
        "from sklearn.linear_model import LogisticRegression\n",
        "\n",
        "lr_model = LogisticRegression(max_iter=1000)\n",
        "\n",
        "lr_model.fit(X_train_tfidf, y_train)"
      ],
